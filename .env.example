# Civic Shield — copy to .env for local dev
# For Cloudflare Pages: Settings → Environment variables → Production
# Add ALL variables below, then redeploy (build must see them or Firebase stays offline).

EXPO_PUBLIC_APP_URL=https://civic-shield.pages.dev

# Firebase project: civic-shield-1cfc4
# Console: https://console.firebase.google.com/project/civic-shield-1cfc4
# Also enable: Authentication → Email/Password + Anonymous
# Authorized domains: civic-shield.pages.dev (+ your custom domain)
# Deploy rules: npm run deploy:rules
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=civic-shield-1cfc4.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=civic-shield-1cfc4
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=civic-shield-1cfc4.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

EXPO_PUBLIC_OPERATOR_PIN=112233
